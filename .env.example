DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
PUBLIC_READ_ONLY_MODE=True
PUBLIC_RATE_LIMIT_PER_MINUTE=180
DJANGO_MYSQL_DATABASE=djangoblog
DJANGO_MYSQL_USER=djangoblog
DJANGO_MYSQL_PASSWORD=change-me
DJANGO_MYSQL_HOST=127.0.0.1
DJANGO_MYSQL_PORT=3306

# Optional: switch base images when Docker Hub is slow or blocked.
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.11-slim-bookworm

# Optional: build-time mirrors for mainland China servers.
APT_MIRROR=https://mirrors.aliyun.com/debian
NPM_REGISTRY=https://registry.npmmirror.com/
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_DEFAULT_TIMEOUT=120
PIP_RETRIES=10

# Optional: expose Django web on another host port.
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Optional: non-Docker process paths for supervisor deployment.
# DJANGOBLOG_PROJECT_DIR=/root/project/djangoblog
# DJANGOBLOG_ENV_FILE=/root/project/djangoblog/.env
# DJANGOBLOG_PYTHON=/root/miniconda3/envs/djangoblog/bin/python
# DJANGOBLOG_GUNICORN=/root/miniconda3/envs/djangoblog/bin/gunicorn
BUILD_FRONTEND=True
NPM_REGISTRY=https://registry.npmmirror.com/

# Optional: Redis cache, for example redis:6379 or 127.0.0.1:6379.
# DJANGO_REDIS_URL=

# Optional: LLM article rewriting.
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=change-me
BLOG_LLM_MODEL=glm-5.1

# Optional: comma-separated RSS/Atom feeds for technical article collection.
# Leave empty to use the built-in curated feeds: Python/Django, cloud native,
# engineering blogs, AI frameworks, cloud providers, and Chinese tech media.
# TECH_BLOG_FEEDS=https://www.djangoproject.com/rss/weblog/,https://realpython.com/atom.xml

# Scheduler batch sizes and optional freshness windows.
TECH_ARTICLE_LIMIT=5
# TECH_ARTICLE_LOOKBACK_HOURS=72
AIHOT_NEWS_LIMIT=30
# AIHOT_NEWS_LOOKBACK_HOURS=24

# Scheduler interval in seconds.
COLLECTOR_INTERVAL=1800

# Gunicorn tuning.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
